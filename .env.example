# =============================================================================
# IA-Notices — Environment configuration
# Copy this file to `.env` and adjust the values. NEVER commit your `.env`.
#
# Defaults are safe: providers, Discord delivery and the scheduler are all
# DISABLED until you explicitly turn them on and supply the required values.
# =============================================================================

# --- Runtime / server --------------------------------------------------------
# Node environment: development | production | test
NODE_ENV=development
# HTTP server bind host and port (healthcheck lives here).
HOST=0.0.0.0
PORT=3000
# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- HTTP client -------------------------------------------------------------
# Per-attempt timeout (ms) and number of retries for outbound requests.
# Generous defaults: some sources (e.g. GDELT) are slow and occasionally flaky.
HTTP_TIMEOUT_MS=20000
HTTP_RETRIES=3

# --- Database ----------------------------------------------------------------
# SQLite file path. In Docker this lives on a mounted volume (see compose).
DATABASE_PATH=data/ia-notices.sqlite

# --- Providers ---------------------------------------------------------------
# NewsAPI.org — https://newsapi.org/docs (requires a key).
NEWSAPI_ENABLED=false
NEWSAPI_KEY=
# GDELT 2.0 DOC API — no key required.
GDELT_ENABLED=false
# The Guardian Open Platform — https://open-platform.theguardian.com (requires a
# free key). The key is sent as the `api-key` query parameter.
GUARDIAN_ENABLED=false
GUARDIAN_KEY=
# Hacker News (Algolia search) — https://hn.algolia.com/api (no key). A
# developer-focused source: new models, tooling and techniques surface here.
HACKERNEWS_ENABLED=false
# Minimum HN points (upvotes) for a story to be surfaced — a quality/relevance
# gate. Higher = stricter (fewer, more notable stories). Default: 30.
HACKERNEWS_MIN_POINTS=30
# Reddit (public JSON listings) — no key. Developer/AI communities: a high-signal
# stream of models, tooling, techniques and tutorials.
REDDIT_ENABLED=false
REDDIT_SUBREDDITS=LocalLLaMA,MachineLearning,ChatGPTCoding,ClaudeAI,OpenAI,artificial
# Minimum upvotes for a post to be surfaced; listing window (hour|day|week|...).
REDDIT_MIN_UPVOTES=25
REDDIT_LISTING=day
# Hugging Face daily papers — https://huggingface.co/papers (no key). Curated
# new AI papers/models (techniques worth learning).
HUGGINGFACE_ENABLED=false
# RSS/Atom feeds of official AI blogs (no key). Comma-separated feed URLs —
# tune this list freely without a rebuild.
RSS_ENABLED=false
RSS_FEEDS=https://huggingface.co/blog/feed.xml,https://openai.com/news/rss.xml,https://blog.google/technology/ai/rss/,https://deepmind.google/blog/rss.xml

# --- Curation ----------------------------------------------------------------
# Comma-separated AI keywords to search and score against (whole-word matched).
# Ordered deliberately: the FIRST terms are specific search queries (per-keyword
# sources like Hacker News only search the leading terms); the TAIL broadens
# scoring with general AI/ML vocabulary so already-curated AI sources (Reddit,
# Hugging Face, blogs) match reliably. Ambiguous bare names sit at the tail.
NEWS_KEYWORDS=LLM,GPT-5,AI agent,open source model,fine-tuning,coding assistant,Hugging Face,language model,model release,open weights,prompt engineering,multimodal,RAG,machine learning,neural network,transformer,diffusion,reasoning,quantization,inference,embeddings,benchmark,GPT-4o,Claude,Gemini,Llama,DeepSeek,Mistral,Qwen,Copilot,AI
# Preferred language (ISO 639-1) when the provider supports it.
NEWS_LANGUAGE=en
# Time window (hours) and maximum number of items per run.
NEWS_LOOKBACK_HOURS=48
NEWS_MAX_ITEMS=20
# Minimum relevance score for an item to be kept/delivered.
NEWS_MIN_SCORE=2

# --- Discord delivery --------------------------------------------------------
# Set ENABLED=true and provide the webhook URL to deliver digests.
# The webhook URL is a SECRET — never commit a real value.
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# --- Scheduling --------------------------------------------------------------
# Run the pipeline on a cron schedule (default: hourly).
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 * * * *

# --- Admin -------------------------------------------------------------------
# Token required to call the protected manual run endpoint (POST /internal/run).
# Generate a strong random value; never commit a real token.
ADMIN_TOKEN=
