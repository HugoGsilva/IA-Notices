# =============================================================================
# IA-Notices — Environment configuration
# Copy this file to `.env` and adjust the values. NEVER commit your `.env`.
#
# Defaults are safe: providers, Discord delivery and the scheduler are all
# DISABLED until you explicitly turn them on and supply the required values.
# =============================================================================

# --- Runtime / server --------------------------------------------------------
# Node environment: development | production | test
NODE_ENV=development
# HTTP server bind host and port (healthcheck lives here).
HOST=0.0.0.0
PORT=3000
# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# --- HTTP client -------------------------------------------------------------
# Per-attempt timeout (ms) and number of retries for outbound requests.
# Generous defaults: some sources (e.g. GDELT) are slow and occasionally flaky.
HTTP_TIMEOUT_MS=20000
HTTP_RETRIES=3

# --- Database ----------------------------------------------------------------
# SQLite file path. In Docker this lives on a mounted volume (see compose).
DATABASE_PATH=data/ia-notices.sqlite

# --- Providers ---------------------------------------------------------------
# NewsAPI.org — https://newsapi.org/docs (requires a key).
NEWSAPI_ENABLED=false
NEWSAPI_KEY=
# GDELT 2.0 DOC API — no key required.
GDELT_ENABLED=false
# The Guardian Open Platform — https://open-platform.theguardian.com (requires a
# free key). The key is sent as the `api-key` query parameter.
GUARDIAN_ENABLED=false
GUARDIAN_KEY=
# Hacker News (Algolia search) — https://hn.algolia.com/api (no key). A
# developer-focused source: new models, tooling and techniques surface here.
HACKERNEWS_ENABLED=false
# Minimum HN points (upvotes) for a story to be surfaced — a quality/relevance
# gate. Higher = stricter (fewer, more notable stories). Default: 50.
HACKERNEWS_MIN_POINTS=50

# --- Curation ----------------------------------------------------------------
# Comma-separated AI keywords to search and score against (whole-word matched).
# Ordered most-specific first: per-keyword sources (e.g. Hacker News) only search
# the leading terms, so keep the high-signal ones up front and ambiguous bare
# model names (Claude/Gemini/Mistral) toward the tail. Override to taste.
NEWS_KEYWORDS=LLM,GPT-5,AI agent,open source model,fine-tuning,coding assistant,Hugging Face,language model,model release,open weights,prompt engineering,multimodal,GPT-4o,Claude,Gemini,Llama 3,DeepSeek,Mistral,Qwen,Copilot
# Preferred language (ISO 639-1) when the provider supports it.
NEWS_LANGUAGE=en
# Time window (hours) and maximum number of items per run.
NEWS_LOOKBACK_HOURS=48
NEWS_MAX_ITEMS=20
# Minimum relevance score for an item to be kept/delivered.
NEWS_MIN_SCORE=2

# --- Discord delivery --------------------------------------------------------
# Set ENABLED=true and provide the webhook URL to deliver digests.
# The webhook URL is a SECRET — never commit a real value.
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# --- Scheduling --------------------------------------------------------------
# Run the pipeline on a cron schedule (default: hourly).
SCHEDULE_ENABLED=false
SCHEDULE_CRON=0 * * * *

# --- Admin -------------------------------------------------------------------
# Token required to call the protected manual run endpoint (POST /internal/run).
# Generate a strong random value; never commit a real token.
ADMIN_TOKEN=
