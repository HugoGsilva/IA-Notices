# =============================================================================
# IA-Notices — Environment configuration (foundation stage)
# Copy this file to `.env` and adjust the values. NEVER commit your `.env`.
#
# Only foundation variables are defined at this stage. Provider keys, Discord
# webhook and scheduling/curation settings are added in later steps, each one
# documented here and in the README when introduced.
# =============================================================================

# Node environment: development | production | test
NODE_ENV=development

# HTTP server bind host and port (healthcheck lives here).
HOST=0.0.0.0
PORT=3000

# Log level: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info
